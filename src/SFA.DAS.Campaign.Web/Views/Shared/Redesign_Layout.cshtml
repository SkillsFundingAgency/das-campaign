                    <circle cx="31.7" cy="30.6" r="3.7" />
                    <circle cx="43.3" cy="17.6" r="3.7" />
                    <circle cx="53.2" cy="23.5" r="3.7" />
                    <circle cx="59.7" cy="33.2" r="3.7" />
                    <circle cx="31.7" cy="30.6" r="3.7" />
