@{
    Layout = "Redesign_Layout";
    ViewBag.Section = "employers";
    
    var headingImageStyle = ViewBag.HeadingImage != null
        ? $"background-image: url('{ViewBag.HeadingImage}')"
        : null;
    var headingColWidth = ViewBag.HeadingImage != null
        ? "one-half"
        : "full";
}

@if (Model.BannerModels != null && Model.BannerModels.Count > 0)
{
    foreach (var banner in Model.BannerModels)
    {
        <partial name="./Banners/_Banner_UserNoHide" model="banner" />
        <partial name="./Banners/_Banner_UserCanHide" model="banner" />
    }
}
<main id="main" class="fiu-main-wrapper">
    <div class="fiu-page-header">
        <div class="fiu-width-container">
            <div class="fiu-page-header__image-wrap">
                <partial name="_Navigation" model="@("employers")" />
                <div class="fiu-page-header__image" style="@headingImageStyle">
                    <span class="fiu-page-header__image-mask"></span>
                </div>
                <div class="govuk-grid-row">
                    <div class="govuk-grid-column-@headingColWidth fiu-page-header__wrap">
                        @if (ViewBag.ParentPageUrl != null)
                        {
                            <a href="@ViewBag.ParentPageUrl" class="govuk-back-link govuk-back-link--inverse fiu-back-link fiu-page-header__back">Back</a>
                        }
                        <strong class="fiu-tag fiu-tag--employers fiu-page-header__tag fiu-feature-text">Employers</strong>
                        <h1 class="govuk-heading-xl fiu-page-heading__title">@ViewBag.PageTitle</h1>
                        @if (ViewBag.PageSummary != null)
                        {
                            <p class="fiu-page-header__content--l">@ViewBag.PageSummary</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>  
    <span class="fiu-grad-row__bg"></span>
    @RenderBody()
</main>