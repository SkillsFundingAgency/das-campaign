@using SFA.DAS.Campaign.Web.Helpers
@using SFA.DAS.Campaign.Web.Renderers
@model SFA.DAS.Campaign.Domain.Content.Page<SFA.DAS.Campaign.Domain.Content.Hub>
@{
    ViewBag.Title = Model.Title;
    Layout = "Redesign_Layout_ApprenticesHub";

    ViewBag.PageTitle = Model.Title;
    ViewBag.PageSummary = Model.Content.Summary;

    ViewBag.HubPage = true;
    ViewBag.HeadingImage = Model.Content.HeaderImage.Url;
}

@functions {
    void RenderCardGroup(string title, IReadOnlyCollection<SFA.DAS.Campaign.Domain.Content.HtmlControl.Card> cards, int maxCards = 100)
    {
        if (cards == null || !cards.Any())
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(title))
        {
            <h2 class="govuk-heading-l fiu-card-group__title">@title</h2>
        }
        
        var cardCount = Math.Min(cards.Count, maxCards);

        <div class="fiu-grid-layout fiu-grid-layout--@cardCount fiu-card-group">
            @foreach (var card in cards.Take(cardCount))
            {
                @card.CardToHtml()
            }
        </div>
    }
}
<div class="fiu-grad-row">
    <div class="fiu-width-container">
        @{ RenderCardGroup(Model.Content.CardsTitle, Model.Content.Cards, 5); }
        <partial name="Panels/_FindAnApprenticeship" />
        @{ RenderCardGroup(Model.Content.CardsTitle2, Model.Content.Cards2); }
        @{ RenderCardGroup(Model.Content.CardsTitle3, Model.Content.Cards3); }
        <partial name="Panels/_GetFreeHelpAndSupport" />
    </div>
</div>